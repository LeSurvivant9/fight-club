      "negate": false,
      "required": true,
      "fields": {
        "value": "(?i)\\b1080p\\b"
      }
    },
    {
      "name": "Generic Multi-Subs",
      "implementation": "ReleaseTitleSpecification",
      "negate": false,
      "required": true,
      "fields": {
        "value": "(?i)(\\bMULTI[- ._]?SUBS?\\b|\\bMSUBS\\b)"
      }
    },
    {
      "name": "Under 900 MiB",
      "implementation": "SizeSpecification",
      "negate": false,
      "required": true,
      "fields": {
        "min": 1,
        "max": 899
      }
    }
  ]
}
