# Authentik Configuration
# Copy this file to .env and fill in the values

# PostgreSQL Database
POSTGRES_DB=authentik
POSTGRES_USER=authentik
POSTGRES_PASSWORD=authentik

# Authentik Security
AUTHENTIK_SECRET_KEY=authentik

# Authentik Settings
AUTHENTIK_ERROR_REPORTING__ENABLED=false
AUTHENTIK_DISABLE_STARTUP_ANALYTICS=true
AUTHENTIK_DISABLE_UPDATE_CHECK=true

# Email Configuration (optional but recommended)
# AUTHENTIK_EMAIL__HOST=smtp.gmail.com
# AUTHENTIK_EMAIL__PORT=587
# AUTHENTIK_EMAIL__USERNAME=your-email@gmail.com
# AUTHENTIK_EMAIL__PASSWORD=your-app-password
# AUTHENTIK_EMAIL__USE_TLS=true
# AUTHENTIK_EMAIL__USE_SSL=false
# AUTHENTIK_EMAIL__TIMEOUT=10
# AUTHENTIK_EMAIL__FROM=Authentik <noreply@yourdomain.com>

# GeoIP (optional - for geo-location features)
# AUTHENTIK_AUTHENTIK__GEOIP=/geoip/GeoLite2-City.mmdb
